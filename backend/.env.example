APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST=localhost
REVERB_SERVER_PORT=8080
REVERB_PORT=8080
REVERB_SCHEME=http

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ── WhatsApp Provider ──────────────────────────────────────────────────────────
# Supported: 'twilio' | 'wasender'
# Switch by changing WHATSAPP_PROVIDER — no code changes needed.
WHATSAPP_PROVIDER=twilio

# ── Twilio (current / fallback) ───────────────────────────────────────────────
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# ── WasenderAPI (QR-linked session — no per-message fees, no template approval)
# 1. Register at https://wasenderapi.com/register
# 2. Create a session → connect via QR
# 3. Copy the session API key below
# 4. Set WASENDER_FROM_NUMBER to the WhatsApp number linked in that session
# 5. Configure webhook URL in session settings:
#    https://your-domain.com/api/webhooks/wasender
WASENDER_API_KEY=
WASENDER_FROM_NUMBER=
WASENDER_WEBHOOK_SECRET=
# Optional: override base URL (leave blank for default)
# WASENDER_BASE_URL=https://www.wasenderapi.com/api

# ── Common Webhook Settings ────────────────────────────────────────────────────
WHATSAPP_WEBHOOK_SECRET=
WHATSAPP_VERIFY_TOKEN=almajd_verify
WHATSAPP_SESSION_WINDOW_HOURS=24
WHATSAPP_TEACHER_CONFIRMATION_MAX_AGE_HOURS=72
