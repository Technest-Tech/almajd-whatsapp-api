<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- For development: Allow cleartext traffic by default -->
    <!-- IMPORTANT: Change cleartextTrafficPermitted to false for production -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>

